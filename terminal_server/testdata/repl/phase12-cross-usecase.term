# Phase 12 cross-use-case fixture for scripts run over seeded simulation state.
sim device new sim-fixture --caps display,keyboard
store put phase12 status seeded --ttl 10s
ui push sim-fixture {"type":"stack","children":[{"type":"text","text":"fixture-ready"}]} --root fixture-root
sim input sim-fixture fixture-banner submit ack
bus emit event fixture.signal sim-fixture:fixture-alert
message post phase12-room fixture-layer2-mutating
board post phase12-board fixture-board-mutating
artifact create lesson fixture-artifact-mutating
canvas annotate phase12-canvas fixture-canvas-mutating
session create lesson phase12-session
session join latest fixture-session-member
message rooms
message ls phase12-room
board ls phase12-board
artifact history latest
canvas ls phase12-canvas
session members latest
sim expect sim-fixture ui fixture-ready --within 2s
sim expect sim-fixture message fixture-alert --within 2s
sim record sim-fixture --duration 2s
sim device rm sim-fixture
