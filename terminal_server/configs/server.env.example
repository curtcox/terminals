# Core transport
TERMINALS_GRPC_HOST=0.0.0.0
TERMINALS_GRPC_PORT=50051
TERMINALS_ADMIN_HTTP_HOST=0.0.0.0
TERMINALS_ADMIN_HTTP_PORT=50053
TERMINALS_LOG_DIR=logs
TERMINALS_LOG_LEVEL=info
TERMINALS_LOG_MAX_BYTES=104857600
TERMINALS_LOG_MAX_ARCHIVES=10
TERMINALS_LOG_STDERR=true
TERMINALS_MDNS_SERVICE=_terminals._tcp.local.
TERMINALS_MDNS_NAME=HomeServer
TERMINALS_VERSION=1

# Runtime tuning
TERMINALS_HEARTBEAT_TIMEOUT_SECONDS=120
TERMINALS_LIVENESS_RECONCILE_INTERVAL_SECONDS=30
TERMINALS_DUE_TIMER_PROCESS_INTERVAL_SECONDS=5
TERMINALS_WAKE_WORD_PREFIXES=assistant,hey terminal

# Storage
TERMINALS_RECORDING_DIR=recordings

# Photo frame
TERMINALS_PHOTO_FRAME_DIR=./assets/photo-frame
TERMINALS_PHOTO_FRAME_INTERVAL_SECONDS=12
TERMINALS_PHOTO_FRAME_HTTP_HOST=0.0.0.0
TERMINALS_PHOTO_FRAME_HTTP_PORT=50052

# Optional: set this to use a CDN/reverse proxy URL instead of the built-in
# photo asset server. When set, the server publishes this value in
# RegisterAck.metadata["photo_frame_asset_base_url"].
# TERMINALS_PHOTO_FRAME_PUBLIC_BASE_URL=https://photos.example.test/photo-frame

# Optional SIP bridge
# TERMINALS_SIP_ENABLED=true
# TERMINALS_SIP_SERVER_URI=sip:home.example
# TERMINALS_SIP_USERNAME=alice
# TERMINALS_SIP_DISPLAY_NAME=Alice
# TERMINALS_SIP_PASSWORD=secret
