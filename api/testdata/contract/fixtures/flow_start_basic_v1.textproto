start_flow: {
  flow_id: "flow-audio-watch"
  plan: {
    nodes: {
      id: "capture"
      kind: "audio.capture"
      exec: "edge"
      exec_policy: EXEC_POLICY_PREFER_CLIENT
      args: {
        key: "stream_id"
        value: "stream-audio-1"
      }
      args: {
        key: "device_id"
        value: "kitchen-terminal"
      }
      args: {
        key: "resource"
        value: "microphone"
      }
      args: {
        key: "stream_kind"
        value: "audio"
      }
      typed_args: {
        device_id: "kitchen-terminal"
        resource: "microphone"
        stream_kind: "audio"
        stream_kind_enum: STREAM_KIND_AUDIO
      }
    }
    nodes: {
      id: "classify"
      kind: "audio.classify"
      exec: "server"
      exec_policy: EXEC_POLICY_SERVER_ONLY
      args: {
        key: "model"
        value: "silence-v1"
      }
    }
    edges: {
      from: "capture"
      to: "classify"
    }
  }
}
